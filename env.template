# ===================================
# Container Backend - Production Environment Template
# ===================================
# Copy this file to .env and update the values
# Generate secure secrets with: openssl rand -hex 64

# ===================================
# Application Settings
# ===================================
NODE_ENV=production
PORT=3000

# ===================================
# Database Configuration
# ===================================
# MongoDB connection string
# Format: mongodb://username:password@host:port/database?authSource=admin
MONGODB_URI=mongodb://localhost/container_backend?authSource=admin

# ===================================
# JWT Authentication
# ===================================
# Generate with: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-64-chars-minimum
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-use-64-chars-minimum

# ===================================
# Admin Bootstrap Configuration
# ===================================
# Single JSON array (valid JSON: no trailing commas). On each server start, any email
# in this list that does NOT already exist in MongoDB gets an ADMIN user created
# (email auto-verified). If the user already exists, that entry is skipped.
#
# App Store / review:
# - Add one object per demo admin, e.g. {"email":"review@yourdomain.com",...}
# - password: minimum 12 characters (enforced in bootstrap.service.ts)
# - organization: "skyline" or "skyrak"
# - Put the SAME email + password in App Store Connect → Review Notes (not in git).
# - After approval, change the password (staff UI) or remove the account if it was review-only.
#
# Mobile app partners use phone + OTP, not this list — create a Partner (admin API/UI)
# and ensure reviewers can receive SMS or use your documented test flow.
#
# Example — append one object before the closing ] (note the comma before {):
# ,{"email":"review@YOURDOMAIN.com","password":"UseALongUniquePhrase!2025","name":"Apple Review","organization":"skyline"}
BOOTSTRAP_ADMINS=[{"email":"admin@skyinventories.com","password":"SkylineAdmin@2025","name":"Skyline Admin","organization":"skyline"},{"email":"superadmin@skyinventories.com","password":"SkylineSuper@2025","name":"Skyline Super Admin","organization":"skyline"},{"email":"admin@skyrak.com","password":"SkyrakAdmin@2025","name":"Skyrak Admin","organization":"skyrak"},{"email":"superadmin@skyrak.com","password":"SkyrakSuper@2025","name":"Skyrak Super Admin","organization":"skyrak"}]

# ===================================
# Email Configuration (Optional)
# ===================================
# SMTP settings for sending emails (verification, password reset, etc.)
# Note: Email sending is optional - app works without it
# For Gmail: Use App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=noreply@skyinventories.com

# ===================================
# SMS Configuration (Twilio) - Optional
# ===================================
# Twilio credentials for sending SMS notifications
# Note: SMS sending is optional - app works without it
# Get credentials from: https://console.twilio.com/
# If not provided, SMS sending will be skipped with a warning

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ===================================
# Partner payments gateway (optional — web / internal checkout only)
# ===================================
# The mobile app does not call checkout. Keep false unless you run hosted
# checkout (web portal, automation). When false, POST checkout/webhook
# return 404; GET /payments/status and /payments/history still work for
# entitlements (DB-backed).

ENABLE_PAYMENTS_GATEWAY=false

# Required only when ENABLE_PAYMENTS_GATEWAY=true (Hubtel)
HUBTEL_API_ID=your-hubtel-api-id
HUBTEL_API_KEY=your-hubtel-api-key
HUBTEL_POS_ID=your-pos-merchant-account-number
HUBTEL_CALLBACK_URL=https://api.skyinventories.com/api/payments/webhook
HUBTEL_RETURN_URL=https://your-webapp.example.com/payments/return
HUBTEL_CANCELLATION_URL=https://your-webapp.example.com/payments/cancel
PARTNER_MONTHLY_SUBSCRIPTION_AMOUNT=0
PARTNER_PROFESSIONAL_SUBSCRIPTION_AMOUNT=0

# ===================================
# Application URLs
# ===================================
# Used in email links and CORS
APP_URL=https://api.skyinventories.com
FRONTEND_URL=https://skyinventories.com
ALLOWED_ORIGINS=https://skyinventories.com,https://www.skyinventories.com,https://api.skyinventories.com

# ===================================
# Security Notes
# ===================================
# 1. NEVER commit this file with real credentials to git
# 2. Use strong passwords (12+ characters, mixed case, numbers, symbols)
# 3. Change all default passwords before deploying
# 4. Rotate secrets regularly in production
# 5. Use environment-specific secrets (don't reuse across environments)
# 6. Keep backups of production secrets in a secure location

